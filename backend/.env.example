# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info
# Frontend origin for CORS
FRONTEND_URL=http://localhost:3000

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
DATABASE_URL=postgresql://otaku:otaku_dev_pw@localhost:5432/otaku_channels
# Direct URL for Prisma migrations (bypasses PgBouncer if used)
DIRECT_DATABASE_URL=postgresql://otaku:otaku_dev_pw@localhost:5432/otaku_channels

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth / JWT ───────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_in_production_use_openssl_rand_base64_64
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
# Cookie secret for signing
COOKIE_SECRET=CHANGE_ME_in_production_use_openssl_rand_base64_32

# ── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=20
AUTH_RATE_LIMIT_WINDOW_MS=900000

# ── External Metadata APIs ───────────────────────────────────────────────────
# Jikan (MyAnimeList public API) — no key required
JIKAN_BASE_URL=https://api.jikan.moe/v4
# AniList GraphQL — no key required for public queries
ANILIST_BASE_URL=https://graphql.anilist.co
# Kitsu REST API — free public API, no key required
KITSU_BASE_URL=https://kitsu.io/api/edge

# ── Streaming APIs (self-hosted) ─────────────────────────────────────────────
# Consumet API — set to your self-hosted instance URL (leave empty to disable)
# GitHub: https://github.com/consumet/api.consumet.org
# Docker: docker run -p 3002:3000 consumet/api.consumet.org
CONSUMET_BASE_URL=

# Aniwatch API — set to your self-hosted instance URL (leave empty to disable)
# GitHub: https://github.com/ghoshRitesh12/aniwatch-api
# Docker: docker run -p 4000:4000 ghcr.io/ghoshritesh12/aniwatch
ANIWATCH_BASE_URL=

# ── Image & Quotes APIs ──────────────────────────────────────────────────────
# Waifu.pics — free public anime image API, no key required
WAIFUPICS_BASE_URL=https://api.waifu.pics
# AnimeChan — free public anime quotes API, no key required
ANIMECHAN_BASE_URL=https://animechan.io

# ── Consumet API (Streaming Sources) ─────────────────────────────────────────
# Self-hosted Consumet instance — see https://github.com/consumet/api.consumet.org
# Required for streaming source lookups; leave blank to disable
# CONSUMET_BASE_URL=http://localhost:3000

# ── Admin ────────────────────────────────────────────────────────────────────
# Comma-separated list of emails automatically granted admin role on register
ADMIN_SEED_EMAILS=admin@otakuchannels.local
