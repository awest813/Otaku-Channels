# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info
# Frontend origin for CORS
FRONTEND_URL=http://localhost:3000

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
DATABASE_URL=postgresql://otaku:otaku_dev_pw@localhost:5432/otaku_channels
# Direct URL for Prisma migrations (bypasses PgBouncer if used)
DIRECT_DATABASE_URL=postgresql://otaku:otaku_dev_pw@localhost:5432/otaku_channels

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth / JWT ───────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_in_production_use_openssl_rand_base64_64
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
# Cookie secret for signing
COOKIE_SECRET=CHANGE_ME_in_production_use_openssl_rand_base64_32

# ── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=20
AUTH_RATE_LIMIT_WINDOW_MS=900000

# ── External Metadata APIs ───────────────────────────────────────────────────
# Jikan (MyAnimeList public API) — no key required
JIKAN_BASE_URL=https://api.jikan.moe/v4
# AniList GraphQL — no key required for public queries
ANILIST_BASE_URL=https://graphql.anilist.co

# ── Admin ────────────────────────────────────────────────────────────────────
# Comma-separated list of emails automatically granted admin role on register
ADMIN_SEED_EMAILS=admin@otakuchannels.local
