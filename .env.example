# !STARTERCONF Duplicate this to .env.local

# DEVELOPMENT TOOLS
# Ideally, don't add them to production deployment envs
# !STARTERCONF Change to true if you want to log data
NEXT_PUBLIC_SHOW_LOGGER="false"

# App version — injected by CI/CD (e.g. git describe --tags)
# NEXT_PUBLIC_APP_VERSION=1.0.0

# Backend API URL (used by Next.js server-side route handlers to proxy requests)
BACKEND_URL=http://localhost:3001

# Data mode for API route handlers (optional, defaults to 'hybrid' when BACKEND_URL is set)
#   mock    — always return static mock data; useful for UI development without a backend
#   backend — always call Fastify; returns 502 if unavailable
#   hybrid  — try backend first, fall back to mock data on failure (recommended default)
DATA_MODE=hybrid

# ── Image & Quotes APIs (called server-side from Next.js route handlers) ──────
# Waifu.pics — free public anime image API, no key required
WAIFUPICS_BASE_URL=https://api.waifu.pics
# AnimeChan — free public anime quotes API, no key required
ANIMECHAN_BASE_URL=https://animechan.io

# ── Error tracking (Sentry) ───────────────────────────────────────────────────
# Leave empty to disable; set to your project DSN to enable Sentry error capture.
# Obtain from: https://sentry.io/settings/<org>/projects/<project>/keys/
# NEXT_PUBLIC_SENTRY_DSN=https://<key>@o<org>.ingest.sentry.io/<project>
# SENTRY_AUTH_TOKEN=   # for source-map uploads during CI builds
# SENTRY_ORG=          # your Sentry organisation slug
# SENTRY_PROJECT=      # your Sentry project slug