# .env.example — copy to .env.local before running the frontend
#
#   cp .env.example .env.local
#
# None of these variables are required for frontend-only (mock) development.
# The app works out of the box with no env file at all.

# ── Data mode ────────────────────────────────────────────────────────────────
# Controls how Next.js API routes fetch data.
#   mock    — always return static mock data (default when BACKEND_URL is unset)
#   hybrid  — try the Fastify backend first, fall back to mock on failure
#   backend — always call Fastify; return 502 if unavailable
DATA_MODE=hybrid

# ── Backend ──────────────────────────────────────────────────────────────────
# URL of the Fastify API server (used server-side by Next.js route handlers).
# Leave unset to use mock data only.
BACKEND_URL=http://localhost:3001

# ── Image & Quotes APIs ──────────────────────────────────────────────────────
# Both are free public APIs — no account or key required.
WAIFUPICS_BASE_URL=https://api.waifu.pics
ANIMECHAN_BASE_URL=https://animechan.io

# ── Developer tools ──────────────────────────────────────────────────────────
# Set to "true" to enable the in-browser dev logger (console output with pathname).
# Always active in NODE_ENV=development regardless of this flag.
NEXT_PUBLIC_SHOW_LOGGER=false

# ── App version (injected by CI/CD) ──────────────────────────────────────────
# Populated automatically by: git describe --tags
# NEXT_PUBLIC_APP_VERSION=1.0.0

# ── Error tracking (Sentry) — optional ───────────────────────────────────────
# Leave commented out to disable Sentry entirely.
# Obtain DSN from: https://sentry.io/settings/<org>/projects/<project>/keys/
# NEXT_PUBLIC_SENTRY_DSN=https://<key>@o<org>.ingest.sentry.io/<project>
# SENTRY_AUTH_TOKEN=   # for source-map uploads during CI builds
# SENTRY_ORG=          # your Sentry organisation slug
# SENTRY_PROJECT=      # your Sentry project slug
