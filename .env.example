# !STARTERCONF Duplicate this to .env.local

# DEVELOPMENT TOOLS
# Ideally, don't add them to production deployment envs
# !STARTERCONF Change to true if you want to log data
NEXT_PUBLIC_SHOW_LOGGER="false"

# Backend API URL (used by Next.js server-side route handlers to proxy requests)
BACKEND_URL=http://localhost:3001

# ── Image & Quotes APIs (called server-side from Next.js route handlers) ──────
# Waifu.pics — free public anime image API, no key required
WAIFUPICS_BASE_URL=https://api.waifu.pics
# AnimeChan — free public anime quotes API, no key required
ANIMECHAN_BASE_URL=https://animechan.io